# Sandbox defaults — auto-loaded by docker compose. Safe dev values only (no real secrets).
# Override locally as needed; CI/production must inject real secrets out-of-band.

# Which compose profiles start by default. "observability" brings Jaeger, OTel Collector,
# Prometheus, Grafana and the infra exporters. Set COMPOSE_PROFILES= (empty) for a lean
# stack (apps + infra only) — or use `make up-core`.
COMPOSE_PROFILES=observability

# --- API auth (PoC). The load tests send this key by default. ------------------
PAYMENT_SECURITY_ENABLED=true
API_KEY=dev-key-change-me

# --- Feature control / JWT (dev only). --------------------------------------------
# HS256 signing secret for the dev JWT issuer (>= 256 bits). Production: RS256/JWKS + secret manager.
JWT_SIGNATURE_SECRET=dev-feature-control-signing-secret-change-me-32b+
# Toggle the dynamic Redis flag store (false = YAML baseline only).
FEATURES_REDIS_ENABLED=true

# --- Redis HA (optional) ----------------------------------------------------------
# Override the whole Redis URI for all apps (env wins over application.yml). Use a Sentinel
# URI for HA (no code change). See deploy/docker-compose.redis-ha.example.yml.
# REDIS_URI=redis-sentinel://redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379/mymaster

# --- Postgres ------------------------------------------------------------------
POSTGRES_DB=sbus
POSTGRES_USER=sbus
POSTGRES_PASSWORD=sbus

# --- Kafka topics --------------------------------------------------------------
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_RF=1

# --- Simulated Core behavior (tweak for demos) ---------------------------------
# Raise latency to force 202/timeouts; raise decline to see 422; raise fail to drive
# transient errors into the retry topics and DLQ.
CORE_LATENCY_MIN_MS=50
CORE_LATENCY_MAX_MS=300
CORE_DECLINE_PCT=10
CORE_FAIL_PCT=0
