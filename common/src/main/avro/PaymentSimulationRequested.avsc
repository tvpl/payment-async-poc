{
  "type": "record",
  "name": "PaymentSimulationRequested",
  "namespace": "com.example.payments.common.avro",
  "doc": "Envelope fields are inlined; occurredAt is epoch millis.",
  "fields": [
    { "name": "eventId", "type": "string" },
    { "name": "eventType", "type": "string" },
    { "name": "eventVersion", "type": "string" },
    { "name": "occurredAt", "type": "long" },
    { "name": "requestId", "type": "string" },
    { "name": "correlationId", "type": "string" },
    { "name": "causationId", "type": ["null", "string"], "default": null },
    { "name": "traceId", "type": ["null", "string"], "default": null },
    { "name": "source", "type": "string" },
    { "name": "payload", "type": "com.example.payments.common.avro.PaymentRequest" }
  ]
}
